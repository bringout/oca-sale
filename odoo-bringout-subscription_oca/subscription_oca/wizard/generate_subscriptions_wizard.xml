<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="generate_subscriptions_wizard_view" model="ir.ui.view">
    <field name="name">generate.subscriptions.wizard.view</field>
    <field name="model">generate.subscriptions.wizard</field>
    <field name="arch" type="xml">
      <form string="Generate subscriptions">
        <group>
          <field name="invoice_date" />
          <field name="payment_term_id" />
          <field name="subscription_ids" widget="many2many_tags" />
        </group>
        <footer>
          <button
            name="action_generate"
            type="object"
            class="oe_highlight"
            string="Generate"
          />
          <button special="cancel" string="Cancel" class="oe_link" />
        </footer>
      </form>
    </field>
  </record>

  <record id="generate_subscriptions_wizard_act_window" model="ir.actions.act_window">
    <field name="name">Generate subscriptions</field>
    <field name="res_model">generate.subscriptions.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <record id="action_generate_subscriptions_wizard" model="ir.actions.server">
    <field name="name">Generate subscriptions</field>
    <field name="model_id" ref="model_sale_subscription" />
    <field name="binding_model_id" ref="model_sale_subscription" />
    <field name="binding_view_types">list,form</field>
    <field name="state">code</field>
    <field name="code">action = records.action_open_generate_subscriptions_wizard()</field>
  </record>
</odoo>
